@startuml
left to right direction
skinparam packageStyle rectangle

' --- ACTORS ---
actor "End User" as User
actor "Data Steward" as Steward
actor "Asset Database" as DB <<External System>>

' --- SYSTEM BOUNDARY ---
rectangle "AMS Intake & Data Quality Platform" {
  
  ' Core Use Cases
  usecase "Submeter Novo Ativo" as UC1
  usecase "Gerir Rascunhos (Drafts)" as UC2
  usecase "Carregar Evidência (PDF)" as UC3
  
  ' Variant 4 Specific Use Cases (Quality & Consistency)
  usecase "Validar Regras de Consistência" as UC4
  usecase "Resolver Inconsistências de Dados" as UC5
  usecase "Exportar Logs de Auditoria" as UC6
  
  ' --- RELATIONS (Includes & Extends) ---
  
  ' Submissão obriga sempre a Validar e a ter Evidência (Include)
  UC1 ..> UC4 : <<include>>
  UC1 ..> UC3 : <<include>>
  
  ' Resolver Inconsistências acontece SE a validação falhar (Extend)
  UC5 .> UC4 : <<extend>>
}

' --- ASSOCIATIONS ---

' User Actions
User --> UC1
User --> UC2
User --> UC3

' Data Steward Actions (Quality Control)
Steward --> UC5
Steward --> UC6

' External System Interaction
' A validação verifica duplicados na BD externa
UC4 -- DB : Verifica Duplicados

@enduml