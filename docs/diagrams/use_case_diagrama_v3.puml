@startuml
title UC-01 — Submeter Ativo (Validações e Estados)

actor Utilizador

rectangle Sistema {

  usecase "UC-01 Submeter Ativo" as UC01

  usecase "Validar Campos Obrigatórios" as UC1
  usecase "Validar Condicional DR" as UC2
  usecase "Detetar Inconsistência DR" as UC3
  usecase "Validar URL Dashboard" as UC4
  usecase "Validar Caducidade Evidências" as UC5
  usecase "Selecionar Owner (AD)" as UC6
  usecase "Verificar Duplicados" as UC7
  usecase "Guardar Draft" as UC8
  usecase "Transitar para Ready to Proceed" as UC9
  usecase "Registar Log de Auditoria" as UC10

}

Utilizador --> UC01

' Includes (sempre executados na submissão)
UC01 --> UC1 : <<include>>
UC01 --> UC2 : <<include>>
UC01 --> UC3 : <<include>>
UC01 --> UC4 : <<include>>
UC01 --> UC5 : <<include>>
UC01 --> UC6 : <<include>>
UC01 --> UC7 : <<include>>
UC01 --> UC10 : <<include>>

' Extend (comportamento opcional)
UC8 ..> UC01 : <<extend>> (Guardar como Draft)
UC9 ..> UC01 : <<extend>> (Submeter Final)
@enduml
