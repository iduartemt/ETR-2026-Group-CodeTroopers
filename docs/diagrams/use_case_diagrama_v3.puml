@startuml
left to right direction
skinparam packageStyle rectangle
skinparam linetype ortho

' ===== ACTORS =====
actor "Transition Lead\n(End User)" as User
actor "Data Steward / Auditor" as Steward
actor "Active Directory\n(External System)" as AD
actor "Asset Database\n(External System)" as DB

' ===== SYSTEM =====
rectangle "AMS Intake & Data Quality Platform" {

  ' --- CORE ---
  usecase "UC-01\nSubmeter Novo Ativo" as UC1

  ' --- SUPPORT (User side) ---
  usecase "UC-02\nGerir Rascunhos" as UC2
  usecase "UC-03\nUpload de Evidências" as UC3

  ' --- VALIDATION ---
  usecase "UC-04\nValidar Regras de Consistência" as UC4
  usecase "UC-05\nResolver Inconsistências" as UC5

  ' --- AUDIT ---
  usecase "UC-06\nConsultar e Exportar Logs" as UC6

  ' ===== RELATIONSHIPS =====
  UC1 ..> UC3 : <<include>>
  UC1 ..> UC4 : <<include>>

  UC5 ..> UC4 : <<extend>>
  UC2 ..> UC1 : <<extend>>
}

' ===== ASSOCIATIONS =====
User --> UC1
User --> UC2

Steward --> UC5
Steward --> UC6

' ===== EXTERNAL SYSTEMS =====
UC1 --> AD
UC4 --> DB
@enduml
